# backend/main.py
from fastapi import FastAPI
from offer_qa.offer_qa import OfferQAContext, answer_offer_question

app = FastAPI()

@app.post("/caddie/qa")
async def caddie_qa(payload: dict):
    ctx = OfferQAContext(**payload["context"])
    question = payload["question"]
    result = answer_offer_question(question, ctx)
    return result.__dict__
